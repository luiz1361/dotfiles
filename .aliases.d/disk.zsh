# Show free disk space for each mounted filesystem, using human-readable suffixes (e.g. 1K, 234M, 2G).
# The alias supplies -h so output is easier to read; use `command df` if you need the original behavior/options.
alias df='df -h'

# Show disk usage for files and directories with human-readable sizes.
# The alias supplies -h so sizes include unit suffixes; use du -sh <path> to get a summarized total.
alias du='du -h'
