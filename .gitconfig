# [user] section: User identity for commits
[user]
    # Your name as it will appear in commits (default: unset, must be set for commits)
    name = Luiz F. C. Martins
    # Your email for commits (default: unset, must be set for commits)
    email = "239121271+luiz1361@users.noreply.github.com"
    # GPG/SSH key used to sign commits (default: unset, enables commit signing if set)
    signingkey = "~/.ssh/id_ed25519.pub"

# [github] section: GitHub-specific settings
[github]
    # Your GitHub username (default: unset, used by some GitHub tools)
    user = luiz1361

# [interactive] section: Interactive Git commands settings
# diffFilter: Command to filter diffs in interactive commands (default: unset)
[interactive]
    diffFilter = delta --color-only --features=interactive

[help]
    # Automatically correct mistyped Git commands;
    # waits a short time before executing the corrected command
    # Default is 0 (no automatic correction)
    autocorrect = 1

# [delta] section: Delta diff viewer settings
# navigate: Enable navigation with n/N (default: false)
# dark: Use dark theme (default: auto-detect)
[delta]
    navigate = true  # use n and N to move between diff sections. Default is false.
    dark = true      # or light = true, or omit for auto-detection. Default is auto.
    side-by-side = true # show diffs side by side. Default is false.
    line-numbers = true # show line numbers in the gutter. Default is false.
    syntax-theme = base16 # choose your favorite syntax theme. Default is 'GitHub' theme.
    hyperlinks = true # make file paths clickable links in supported terminals. Default is false.
	file-style = bold yellow ul # style for file names in diffs. Default is plain.
	file-decoration-style = yellow ol ul # decoration style for file names. Default is plain.
	hunk-header-decoration-style = blue # decoration style for hunk headers. Default is plain.
	hunk-header-line-number-style = purple bold # style for line numbers in hunk headers. Default is plain.

# [merge] section: Merge conflict style settings
# conflictStyle: Style for merge conflicts (default: 'merge')
[merge]
    conflictStyle = zdiff3
    # Include summaries of merged commits in newly created merge commit messages
    # Default value: false
    log = true

# [core] section: Core Git settings
[core]
    # Default pager for Git commands (default: less)
    pager = delta

    # This is my global Git ignore file.
    # Patterns here are applied to all repositories for this user.
    # Repository-specific .gitignore files are still used and merged with these rules.
    excludesfile = ~/.gitignore
    # Default editor for Git commands (default: system editor, e.g., vi)
    editor = nvim
    # Whitespace rules for git diff and apply (default: trailing-space)
    # space-before-tab: error for spaces before tabs at line start
    # -indent-with-non-tab: disables error for non-tab indentation
    # trailing-space: error for spaces at line end
    whitespace = space-before-tab,-indent-with-non-tab,trailing-space

# [pull] section: Behavior for git pull
[pull]
    # Use merge instead of rebase when pulling (default: false, i.e., merge)
    rebase = false

# [init] section: Default branch name for new repos
[init]
    # Default branch name when initializing a repo (default: 'master')
    defaultBranch = main

# [gpg] section: GPG signing settings
[gpg]
    # Use SSH keys for commit signing (default: gpg, enables SSH signing)
    format = ssh

# [commit] section: Commit signing settings
[commit]
    # Always sign commits (default: false, only signs if --gpg-sign is used)
    gpgsign = true
    template = "~/.gitmessage"

# [filter "lfs"] section: Git LFS (Large File Storage) settings
[filter "lfs"]
    # Command to run when checking out files (default: git-lfs smudge)
    smudge = git-lfs smudge -- %f
    # Command to run for filtering files (default: git-lfs filter-process)
    process = git-lfs filter-process
    # Require LFS filter for this repo (default: false)
    required = true
    # Command to run when adding files (default: git-lfs clean)
    clean = git-lfs clean -- %f
